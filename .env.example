# LLM API (required for all archetypes)
# Get from https://platform.openai.com → API keys
OPENAI_API_KEY=your-key-here

# Web search API (required for archetype A: Exploratory Research and Synthesis)
# Free tier at https://tavily.com (about 1000 searches per month)
TAVILY_API_KEY=your-key-here

# Experiment seed (deterministic instance ordering and synthetic CRM data)
RANDOM_SEED=42

# Note: the experiment uses a local SQLite database at data/crm.db, built by
# experiments/load_db.py. No external database service is required.
